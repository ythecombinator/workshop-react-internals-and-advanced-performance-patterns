{
  "name": "workshop-react-internals-and-advanced-performance-patterns",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "format": "prettier --write ./src/",
    "agents:doctor": "npx react-doctor@latest . --verbose",
    "agents:grab": "npx grab@latest init",
    "codemod:jscodeshift:oss:remove-forward-ref": "npx codemod react/19/remove-forward-ref --target src/components/demos/compiling/jscodeshift-oss.tsx",
    "codemod:jscodeshift:oss:use-context-hook": "npx codemod react/19/use-context-hook --target src/components/demos/compiling/jscodeshift-oss.tsx",
    "codemod:jscodeshift:custom:extract-styles": "npx jscodeshift -t src/codemods/extract-inline-styles.ts --parser=tsx --extensions=tsx src/components/demos/compiling/jscodeshift-custom.tsx",
    "codemod:jscodeshift:custom:extract-handlers": "npx jscodeshift -t src/codemods/extract-inline-handlers.ts --parser=tsx --extensions=tsx src/components/demos/compiling/jscodeshift-custom.tsx",
    "codemod:ts-morph": "npx tsx src/codemods/enforce-prop-interfaces.ts src/components/demos/compiling/ts-morph.tsx",
    "codemod:ast-grep": "npx ast-grep scan -r src/codemods/lazy-state-initializer.yaml --update-all src/components/demos/compiling/ast-grep.tsx"
  },
  "dependencies": {
    "@preact/preset-vite": "2.10.5",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@visx/axis": "3.12.0",
    "@visx/brush": "3.12.0",
    "@visx/gradient": "3.12.0",
    "@visx/mock-data": "3.12.0",
    "@visx/pattern": "3.12.0",
    "@visx/responsive": "3.12.0",
    "@visx/scale": "3.12.0",
    "bippy": "0.5.39",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "d3-array": "3.2.4",
    "fast-deep-equal": "3.1.3",
    "its-fine": "2.0.0",
    "jquery": "4.0.0",
    "koota": "0.6.6",
    "lucide-react": "1.8.0",
    "preact": "10.29.1",
    "react": "19.2.5",
    "react-content-loader": "7.1.2",
    "react-dom": "19.2.5",
    "react-router-dom": "7.14.0",
    "react-window": "2.2.7",
    "tailwind-merge": "3.5.0",
    "tailwindcss-animate": "1.0.7"
  },
  "devDependencies": {
    "@ast-grep/cli": "0.42.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@tailwindcss/vite": "4.2.2",
    "@types/jquery": "4.0.0",
    "@types/jscodeshift": "17.3.0",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-window": "2.0.0",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.27",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "jscodeshift": "17.3.0",
    "postcss": "8.5.9",
    "prettier": "3.8.2",
    "react-grab": "0.1.32",
    "tailwindcss": "4.2.2",
    "tinybench": "6.0.1",
    "ts-morph": "28.0.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vite": "8.0.8"
  }
}
